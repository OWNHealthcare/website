# In Vercel unter Settings → Environment Variables eintragen (nicht committen!)

# Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Resend → API Keys (Sending access reicht)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Basis-URL der Seite, wird für den Bestätigungslink benutzt
SITE_URL=https://ownhealth.eu

# Absender – die Domain muss in Resend verifiziert sein
FROM_EMAIL=OWN Health <noreply@ownhealth.eu>
